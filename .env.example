# Copy to .env.local — Next.js app (localhost:3000). Course APIs run in this repo, not :4000.
#
# Regenerate DB types: pnpm db:types (uses npx supabase; run `npx supabase login` once if prompted)

NODE_ENV=development

# --- Supabase (client + server) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: migrations via `pnpm db:migrate`
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# --- AI / research / voice ---
OPENAI_API_KEY=
EXA_API_KEY=
EXA_SEARCH_TIMEOUT_MS=12000
EXA_SEARCH_RETRIES=2
AETHEX_API_KEY=

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Legacy if you still run grasp-api alongside Next:
# NEXT_PUBLIC_API_URL=http://localhost:4000
