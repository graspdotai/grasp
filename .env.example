# Copy to apps/web/.env.local and configure apps/api as needed

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API — use PORT=4000 when starting (see npm run dev:api)
# PORT=4000

# Supabase — from `npx supabase status` when running locally
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# AI / Voice (add when integrating)
# OPENAI_API_KEY=
# AETHEXAI_API_KEY=
