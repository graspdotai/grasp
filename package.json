{
  "name": "grasp",
  "version": "0.1.0",
  "private": true,
  "description": "Voice-first AI learning platform",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev -w web\" \"npm run start -w api\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "PORT=4000 npm run start -w api",
    "build": "npm run build -w web",
    "lint": "npm run lint -w web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
